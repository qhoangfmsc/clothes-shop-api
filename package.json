{
  "name": "clothes-shop-api",
  "version": "0.0.1",
  "description": "Ori Baebi — Backend API for fashion e-commerce",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npx --yes @nestjs/cli build",
    "format": "biome format --write ./src",
    "dev": "npx --yes @nestjs/cli start --watch",
    "start": "node dist/src/main.js",
    "start:prod": "yarn typeorm migration:run -d data-source.ts && node dist/src/main.js",
    "lint": "biome check ./src",
    "lint:fix": "biome check --fix ./src",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "bash -c 'yarn typeorm migration:generate src/migrations/$1 -d data-source.ts' --",
    "migration:create": "bash -c 'yarn typeorm migration:create src/migrations/$1' --",
    "migration:run": "yarn typeorm migration:run -d data-source.ts",
    "migration:revert": "yarn typeorm migration:revert -d data-source.ts",
    "prepare": "husky",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit --verbose --passWithNoTests"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.2.4",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.3.0",
    "lodash": "^4.17.21",
    "nanoid": "^3.3.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.23",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "webpack": "^5.104.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*(\\.|e2e-)spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1",
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@core/(.*)$": "<rootDir>/core/$1",
      "^@/(.*)$": "<rootDir>/modules/$1"
    }
  },
  "lint-staged": {
    "*.ts": "biome check --fix --no-errors-on-unmatched"
  }
}
